# ==========================================================================
# UNISMUH AI Cloud - Backend environment (CONTOH)
# Salin ke `.env` lalu sesuaikan:  cp .env.example .env
# JANGAN commit file .env (berisi rahasia).
# ==========================================================================

# --- Umum ---
PROJECT_NAME=UNISMUH ComputeHub
ENV=production
API_V1_PREFIX=/api/v1
HOST=127.0.0.1
PORT=8000

# --- Keamanan (WAJIB diganti) ---
# Buat string acak panjang, mis:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=GANTI-DENGAN-STRING-ACAK-PANJANG
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Rate limit login (anti brute-force) ---
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_BLOCK_SECONDS=600

# --- Database ---
# Default SQLite (tanpa install apa pun):
DATABASE_URL=sqlite+aiosqlite:///./unismuh_ai_cloud.db
# Jika kampus menyediakan PostgreSQL, ganti jadi (contoh):
# DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/NAMA_DB
# Supabase (pakai Connection Pooler, ganti [REF]/[PASSWORD]/region):
# DATABASE_URL=postgresql+asyncpg://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# DB_REQUIRE_SSL=true   # wajib SSL untuk Postgres remote (Supabase)

# --- CORS (frontend) ---
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Logging (stdout + berkas dengan rotasi) ---
LOG_DIR=./logs
LOG_FILE=app.log
LOG_LEVEL=INFO
LOG_MAX_BYTES=5000000
LOG_BACKUP_COUNT=5
LOG_TO_FILE=true

# --- Scheduler & monitoring ---
SCHEDULER_MODE=local
SCHEDULER_INTERVAL_SECONDS=5
MONITOR_SAMPLE_INTERVAL_SECONDS=10
MAX_CONCURRENT_JOBS=2

# --- Kuota resource (0 = auto-detect) ---
TOTAL_CPU_CORES=0
TOTAL_MEMORY_MB=0
RESERVED_MEMORY_MB=2048
RESERVED_CPU_CORES=2

# --- Eksekusi job ---
JOBS_DIR=./_jobs
ENABLE_JOB_EXECUTION=true

# --- Provisioning Docker per-user (1 user 1 docker) — OPT-IN, default NONAKTIF ---
# Aktifkan HANYA bila service backend punya akses docker TANPA mengubah setelan sistem,
# mis. sudo passwordless yang SUDAH ada (DOCKER_CMD="/usr/bin/sudo -n /usr/bin/docker")
# atau user sudah di grup docker. JANGAN ubah daemon/sudoers/grup demi fitur ini.
# Semua operasi HANYA menyentuh container bernama PERSIS ch-user-<id> (tak pernah prune).
# DOCKER_PROVISION_ENABLED=false
# JOB_RUNTIME=unshare   # "unshare" (default, sandbox host) atau "docker" (job jalan di container per-job ch-job-<id>; butuh DOCKER_PROVISION_ENABLED + image ch-compute yang LENGKAP librarynya)
# INTERACTIVE_RUNTIME=unshare   # "unshare" (default) atau "docker" (kernel notebook jalan di container ch-compute, --network host; butuh DOCKER_PROVISION_ENABLED)
# DOCKER_CMD=docker
# DOCKER_USER_IMAGE=ch-compute:latest   # image Python+torch (build: backend/docker/ch-compute.Dockerfile); atau nvidia/cuda:12.1.0-base-ubuntu22.04
# DOCKER_USER_PREFIX=ch-user-
# DOCKER_USER_DATA_ROOT=~/.computehub/users
# DOCKER_USER_GPUS=all
# DOCKER_USER_MEMORY=8g
# DOCKER_USER_CPUS=2
# DOCKER_USER_PIDS_LIMIT=2048

# --- Retensi & pembersihan otomatis (hemat disk server) ---
JOB_RETENTION_DAYS=14
ALERT_RETENTION_DAYS=30
CLEANUP_INTERVAL_HOURS=6

# ==========================================================================
# --- ENFORCEMENT GPU (WAJIB GPU, TIDAK BOLEH CPU) ---
# ENFORCE_GPU=true        -> tanpa GPU, job ditolak (tidak jalan di CPU).
# ALLOW_CPU_FALLBACK=false -> dilarang fallback ke CPU.
# REQUIRE_CUDA_PREFLIGHT  -> cek torch.cuda sebelum command utama dijalankan.
# GPU_VISIBLE_DEVICES     -> kosong = semua GPU; atau batasi mis "0,1".
# GPU_MIN_FREE_MEMORY_MB  -> GPU dianggap "bebas" bila free memory >= nilai ini.
# ==========================================================================
ENFORCE_GPU=true
ALLOW_CPU_FALLBACK=false
REQUIRE_CUDA_PREFLIGHT=true
GPU_VISIBLE_DEVICES=
GPU_MIN_FREE_MEMORY_MB=1024

# --- Sampling resource per-job (RAM/VRAM/GPU diukur sistem) ---
JOB_SAMPLE_INTERVAL_SECONDS=2

# --- Batas waktu eksekusi job (timeout, detik) ---
DEFAULT_JOB_TIME_LIMIT_SECONDS=3600
STUDENT_MAX_TIME_LIMIT_SECONDS=7200
MAX_JOB_TIME_LIMIT_SECONDS=86400

# --- Upload project (ZIP) ---
MAX_UPLOAD_SIZE_MB=200
MAX_UPLOAD_UNCOMPRESSED_MB=1024
MAX_UPLOAD_FILES=5000

# --- Auto install dependency (requirements.txt, terisolasi per job) ---
AUTO_PIP_INSTALL=true
PIP_INSTALL_TIMEOUT_SECONDS=600

# --- Kuota GPU harian mahasiswa (detik, rolling 24 jam; 0 = tanpa batas) ---
STUDENT_DAILY_GPU_SECONDS_QUOTA=14400

# ==========================================================================
# --- KEBIJAKAN PERAN (mahasiswa dibatasi, dosen bebas) ---
# Mahasiswa: prioritas TERKUNCI (mengikuti urutan submit/FIFO) + kuota job.
# Dosen/Admin: boleh atur prioritas (selalu di atas mahasiswa).
# ==========================================================================
STUDENT_MAX_CONCURRENT_JOBS=1
STUDENT_MAX_GPU_MEMORY_MB=0
DOSEN_DEFAULT_PRIORITY=20
DOSEN_MAX_PRIORITY=50
ADMIN_MAX_PRIORITY=100

# --- Sumber job dari Git (GitHub) ---
ALLOWED_GIT_HOSTS=github.com
GIT_CLONE_TIMEOUT_SECONDS=180

# --- Peringatan resource & email laporan ---
# Penerima laporan PDF saat batas resource terlampaui (dipisah koma; kosong = email admin).
ALERT_EMAIL_TO=
ALERT_CHECK_INTERVAL_SECONDS=120
ALERTS_DIR=./_alerts
# SMTP untuk pengiriman email (kosongkan SMTP_HOST untuk menonaktifkan):
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=20

# --- Admin pertama (dibuat saat seed/startup) ---
# WAJIB diisi password kuat (>=8 karakter) untuk instalasi BARU.
# Tanpa ini, startup pada DB kosong akan ditolak demi keamanan.
FIRST_ADMIN_NAME=Administrator
FIRST_ADMIN_EMAIL=admin@unismuh.ac.id
FIRST_ADMIN_PASSWORD=

# --- Asisten AI notebook (chat ala Copilot di panel kanan notebook) ---
# Provider OpenAI-compatible. Default base URL = GitHub Models. Asisten AKTIF
# begitu ASSISTANT_API_KEY diisi (mis. GitHub Personal Access Token, scope
# models:read). Tanpa kunci, panel tetap muncul dgn pesan fallback yang jelas.
# Bisa diarahkan ke OpenAI/OpenRouter/Groq atau server vLLM/Ollama lokal:
#   - OpenAI         : ASSISTANT_API_BASE=https://api.openai.com/v1 , MODEL=gpt-4o-mini
#   - vLLM/Ollama    : ASSISTANT_API_BASE=http://127.0.0.1:8001/v1 , MODEL=<nama model>
ASSISTANT_ENABLED=true
ASSISTANT_API_BASE=https://models.github.ai/inference
# ASSISTANT_API_KEY: RAHASIA -> isi HANYA di .env (jangan commit). Kosong = fallback.
ASSISTANT_API_KEY=
ASSISTANT_MODEL=openai/gpt-4o-mini
ASSISTANT_PROVIDER_LABEL=GitHub Models
ASSISTANT_MAX_TOKENS=1024
ASSISTANT_TEMPERATURE=0.2
ASSISTANT_TIMEOUT_SECONDS=60

# --- SSO Unismuh (Keycloak / OpenID Connect) ---
# Login via SSO kampus (OIDC Authorization Code + PKCE). ADDITIVE: login lokal tetap ada.
# 1) Daftarkan app ke admin SSO: APP_ID (mis. computehub), tipe confidential,
#    REDIRECT_URIS=https://<domain>/api/v1/auth/sso/callback  -> dapat client_id + client_secret.
# 2) Isi nilai di bawah, set SSO_ENABLED=true, restart backend.
# Semua endpoint diambil dari discovery {SSO_ISSUER}/.well-known/openid-configuration.
SSO_ENABLED=false
SSO_ISSUER=https://sso.if.unismuh.ac.id/realms/unismuh
SSO_CLIENT_ID=computehub
SSO_CLIENT_SECRET=
# Opsional (default sudah sesuai Unismuh):
# SSO_REDIRECT_URI=            # kosong -> APP_PUBLIC_URL + /api/v1/auth/sso/callback
# SSO_SCOPES=openid profile email
# SSO_ADMIN_ROLES=             # peran SSO staf yg jadi admin ComputeHub (mis. laboran,pimpinan)
# SSO_DOSEN_EMAIL_DOMAIN=unismuh.ac.id
# SSO_MAHASISWA_EMAIL_DOMAIN=student.unismuh.ac.id

