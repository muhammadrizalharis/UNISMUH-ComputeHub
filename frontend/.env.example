# Backend yang dituju saat `npm run dev` (Vite proxy /api -> sini).
# Default 8088. Ganti bila backend pakai port lain.
VITE_API_PROXY=http://127.0.0.1:8088

# URL backend PUBLIK untuk deploy terpisah (mis. Vercel).
# Kosongkan untuk same-origin (frontend disajikan backend di server kampus).
# Contoh: VITE_API_BASE_URL=https://computehub-backend.contoh.com
VITE_API_BASE_URL=
